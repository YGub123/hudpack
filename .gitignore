# 构建产物 / 运行时生成
out/
__pycache__/
src/__pycache__/
hudpack_check.txt
hudpack.exe

# 个人数据(每个用户自己的图标账本与样式配置,首次运行自动生成)
icons/registry.json
hud_style.json

# vanilla/ 里的 Mojang 资产不入库(首次运行从用户自己的客户端 jar 提取)
# 只保留可再分发的 GNU Unifont 与本工具自写的 unifont.json
vanilla/assets/minecraft/textures/
vanilla/assets/minecraft/font/*.json
vanilla/assets/minecraft/font/include/*.json
!vanilla/assets/minecraft/font/include/unifont.json
